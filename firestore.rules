rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) 
        && data.uid is string && data.uid.size() <= 128
        && data.role in ['client', 'provider']
        && (data.get('email', '') is string && data.get('email', '').size() <= 255)
        && (data.get('name', 'User') is string && data.get('name', 'User').size() >= 2 && data.get('name', 'User').size() <= 100)
        && (data.get('phone', '') is string && data.get('phone', '').size() <= 20)
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 1000)
        && (data.get('gender', '') is string && data.get('gender', '').size() <= 20)
        && (data.get('interests', []) is list && data.get('interests', []).size() <= 50)
        && (data.get('locationCoords', null) == null || (data.locationCoords.latitude is number && data.locationCoords.longitude is number));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'text', 'timestamp'])
        && data.senderId is string && data.receiverId is string
        && data.text is string && data.text.size() > 0 && data.text.size() <= 2000
        && data.timestamp is timestamp;
    }

    function isValidWaitlist(data) {
      return data.keys().hasAll(['clientId', 'providerId', 'tier', 'timestamp', 'status'])
        && data.clientId is string && data.providerId is string
        && data.tier in ['Basic', 'Premium', 'Luxury']
        && data.status in ['active', 'promoted', 'cancelled']
        && data.timestamp is timestamp;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['providerId', 'clientId', 'date', 'time', 'status', 'price'])
        && data.providerId is string && data.clientId is string
        && data.status in ['pending', 'confirmed', 'in_progress', 'completed', 'paid', 'closed', 'cancelled', 'disputed']
        && data.price is number && data.price >= 0 && data.price <= 1000000
        && data.time is string && data.time.size() <= 50;
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['bookingId', 'providerId', 'clientId', 'amount', 'status', 'total'])
        && data.bookingId is string && data.providerId is string && data.clientId is string
        && data.amount is number && data.amount >= 0
        && data.total is number && data.total >= data.amount
        && data.status in ['sent', 'approved', 'disputed', 'paid'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['invoiceId', 'bookingId', 'amount', 'status', 'timestamp', 'transactionId', 'clientId', 'providerId'])
        && data.invoiceId is string && data.bookingId is string 
        && data.amount is number && data.amount > 0
        && data.transactionId is string && data.transactionId.size() <= 128
        && data.clientId is string && data.providerId is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'timestamp', 'type'])
        && data.userId is string && data.title is string && data.title.size() <= 255
        && data.message is string && data.message.size() <= 1000
        && data.type is string && data.timestamp is timestamp;
    }

    function isValidBlock(data) {
      return data.keys().hasAll(['providerId', 'date'])
        && data.providerId is string && data.date is string;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'label', 'icon', 'color'])
        && data.id is string && data.label is string
        && data.icon is string && data.color is string;
    }

    // --- Collection Routes ---

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid && emailVerified();
      allow update: if isOwner(userId) && isValidUser(incoming()) && emailVerified() && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'image', 'location', 'bio', 'isAvailable', 'interests', 
          'gender', 'locationCoords', 'isAwaitingVerification', 'joined', 
          'category', 'tier', 'services', 'pricePerHour', 'portfolioUrl', 
          'isCatalogComplete', 'updatedAt', 'email', 'createdAt'
        ])
      );
    }

    match /messages/{messageId} {
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && emailVerified() && isOwner(incoming().senderId) && isValidMessage(incoming());
    }

    match /waitlist/{entryId} {
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow get: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().providerId));
      allow create: if isSignedIn() && emailVerified() && isOwner(incoming().clientId) && isValidWaitlist(incoming());
      allow update: if isSignedIn() && emailVerified() && (isOwner(existing().clientId) || isOwner(existing().providerId)) && isValidWaitlist(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().providerId));
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().providerId));
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow create: if isSignedIn() && emailVerified()
        && isOwner(incoming().clientId) 
        && isValidBooking(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().providerId));
      
      allow update: if isSignedIn() && emailVerified() && isValidBooking(incoming()) && (
        // Terminal State Lock
        !(existing().status in ['closed', 'cancelled']) &&
        (
          // Client can cancel or approve
          (isOwner(existing().clientId) && (incoming().status in ['cancelled', 'paid', 'closed', 'disputed'] || incoming().status == existing().status)) ||
          // Provider can confirm, start, or complete
          (isOwner(existing().providerId) && (incoming().status in ['confirmed', 'in_progress', 'completed'] || incoming().status == existing().status))
        )
      );
    }

    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow create: if isSignedIn() && isOwner(incoming().providerId) && isValidInvoice(incoming());
      allow update: if isSignedIn() && emailVerified() && isValidInvoice(incoming()) && (
        // Terminal State Lock
        !(existing().status in ['approved', 'paid']) &&
        (
          (isOwner(existing().clientId) && incoming().status in ['approved', 'disputed']) ||
          (isOwner(existing().providerId) && incoming().status == existing().status)
        )
      );
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      // Transactions should ideally be created by a secure backend trigger, but for this simulation, 
      // we ensure the user is at least one of the parties.
      allow create: if isSignedIn() && (incoming().clientId == request.auth.uid || incoming().providerId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Notifications are system-driven for this app
      allow create: if isSignedIn() && isValidNotification(incoming()) && (
        incoming().userId == request.auth.uid || 
        incoming().get('type', '') in ['invoice_sent', 'task_completed', 'payment_received', 'dispute_raised', 'booking_status']
      );
      allow update: if isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /blockedDates/{blockId} {
      allow get: if true; // Publicly visible for availability check
      allow list: if true;
      allow create: if isSignedIn() && isOwner(incoming().providerId) && isValidBlock(incoming());
      allow delete: if isSignedIn() && isOwner(existing().providerId);
    }
  }
}
